{
  "name": "@posteria/ledger",
  "version": "0.1.1",
  "description": "Open, append-only record of what crosses an AI agent's I/O boundary.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/posteria-ai/ledger.git"
  },
  "homepage": "https://github.com/posteria-ai/ledger#readme",
  "bugs": {
    "url": "https://github.com/posteria-ai/ledger/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LIMITATIONS.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsc --project tsconfig.test.json && node --test $(find .test-dist/test -name '*.test.js')",
    "conformance": "tsc --project tsconfig.test.json && node --test $(find .test-dist/test/conformance -name '*.conformance.js')"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
